@model IEnumerable<SchoolManagementSystem2.Models.Student>

@{
    ViewData["Title"] = "Students";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">
            <i class="bi bi-mortarboard-fill"></i> Student Dashboard
        </h2>


        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add New Student
        </a>
    </div>

    <!-- Card -->
    <div class="card shadow-sm">
        <div class="card-body">

            <!-- 🔍 Search Box -->
            <form asp-action="Index" method="get" class="row mb-3">
                <div class="col-md-6">
                    <input type="text"
                           name="searchString"
                           class="form-control"
                           placeholder="Search by first name..."
                           value="@Context.Request.Query["searchString"]" />
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        Search
                    </button>
                </div>

                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-secondary w-100">
                        Clear
                    </a>
                </div>
            </form>

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th>Photo</th>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>DOB</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Gender</th>
                        <th>Enrollment Date</th>
                        <th style="width: 180px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Photopath))
                                {
                                    <img src="@item.Photopath" width="60" height="60" style="border-radius:50%;" />
                                }
                                else
                                {
                                    <span>No Image</span>
                                }
                            </td>
                            <td>@item.FirstName</td>
                            <td>@item.LastName</td>
                            <td>@item.DateofBirth.ToString("dd-MM-yyyy")</td>
                            <td>@item.PhoneNumber</td>
                            <td>@item.Email</td>
                            <td>@item.Gender</td>
                            <td>@item.EnrollmentDate.ToString("dd-MM-yyyy")</td>

                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.ID"
                                   class="btn btn-sm btn-warning me-1">
                                    Edit
                                </a>

                                <a asp-action="Details" asp-route-id="@item.ID"
                                   class="btn btn-sm btn-info me-1 text-white">
                                    View
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.ID"
                                   class="btn btn-sm btn-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>
