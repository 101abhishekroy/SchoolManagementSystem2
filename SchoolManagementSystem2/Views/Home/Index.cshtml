@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <!-- Page Title -->
    <div class="mb-4 text-center">
        <h1 class="fw-bold text-primary">
            <i class="bi bi-speedometer2 me-2"></i> Dashboard
        </h1>
        <p class="text-muted">
            Welcome to School Management System
        </p>
    </div>

    <!-- Dashboard Cards -->
    <div class="row g-4">

        <!-- Students -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill text-primary fs-1"></i>
                    <h5 class="mt-3">Students</h5>
                    <p class="text-muted">
                        Manage student information and enrollment.
                    </p>
                    <a asp-controller="Students" asp-action="Index"
                       class="btn btn-primary btn-sm">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- Teachers -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-person-badge-fill text-success fs-1"></i>
                    <h5 class="mt-3">Teachers</h5>
                    <p class="text-muted">
                        Add and manage teachers.
                    </p>
                    <a asp-controller="Teachers" asp-action="Index"
                       class="btn btn-success btn-sm">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- Courses -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-book-fill text-warning fs-1"></i>
                    <h5 class="mt-3">Courses</h5>
                    <p class="text-muted">
                        Manage courses and subjects.
                    </p>
                    <a asp-controller="Courses" asp-action="Index"
                       class="btn btn-warning btn-sm">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- Attendance -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-calendar-check-fill text-info fs-1"></i>
                    <h5 class="mt-3">Attendance</h5>
                    <p class="text-muted">
                        Track daily attendance.
                    </p>
                    <a asp-controller="Attendances" asp-action="Index"
                       class="btn btn-info btn-sm text-white">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- Reports -->
        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark-text-fill text-danger fs-1"></i>
                    <h5 class="mt-3">Reports</h5>
                    <p class="text-muted">
                        View reports and summaries.
                    </p>
                    <a asp-controller="Reports" asp-action="Index"
                       class="btn btn-danger btn-sm">
                        Open
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
